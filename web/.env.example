# Configurações da Aplicação Flask
# Copie este arquivo para .env e preencha com seus valores reais

# Chave secreta do Flask (gere uma nova com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=sua_chave_secreta_aqui_muito_segura_64_caracteres

# Banco de Dados
# Desenvolvimento (SQLite):
DATABASE_URL=sqlite:///app.db

# Produção (PostgreSQL):
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/app_motoristas

# Configurações do Stripe
# Obtenha suas chaves em: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLIC_KEY=pk_test_sua_chave_publica_stripe_aqui
STRIPE_SECRET_KEY=sk_test_sua_chave_secreta_stripe_aqui

# Webhook do Stripe
# Configure em: https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_sua_chave_webhook_stripe_aqui

# Configurações Opcionais

# Modo Debug (True apenas em desenvolvimento!)
FLASK_ENV=development
FLASK_DEBUG=True

# Host e Porta
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
