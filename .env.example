# Configurações da Aplicação
SECRET_KEY=your-secret-key-here-change-in-production

# Banco de Dados
DATABASE_URL=sqlite:///motoristas.db

# Asaas Gateway de Pagamento
# Para testar: use https://sandbox.asaas.com
# Para produção: use https://api.asaas.com
ASAAS_API_KEY=your_asaas_api_key_here
ASAAS_WALLET_ID=your_asaas_wallet_id_here
ASAAS_API_URL=https://sandbox.asaas.com/api/v3

# Recuperação de senha
# Em produção: mantenha false e implemente envio de token por email.
PASSWORD_RESET_DEMO=false
PASSWORD_RESET_DEMO_PASSWORD=123456

# Preços em centavos (opcional - usa valores padrão se não definido)
PRICE_MONTHLY=1190
PRICE_QUARTERLY=3490
PRICE_ANNUAL=9990
